apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: grafana
  namespace: monitoring
spec:
  parentRefs:
    - name: main-gateway
      group: gateway.networking.k8s.io
      kind: Gateway
      namespace: gateway
  hostnames:
    - grafana.lippok.dev
  rules:
    - matches:
        - path:
            type: PathPrefix
            value: /
      backendRefs:
        - name: kube-prometheus-stack-grafana
          group: ""
          kind: Service
          port: 80
          weight: 1

