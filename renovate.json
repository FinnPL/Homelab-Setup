{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits"
  ],
  "labels": [
    "dependencies"
  ],
  "nix": {
    "enabled": true
  },
  "terraform": {
    "enabled": true
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/(^|/)apps/.+\\.ya?ml$/",
      "/(^|/)charts/.+\\.ya?ml$/"
    ]
  },
  "argocd": {
    "managerFilePatterns": [
      "/(^|/)apps/.+\\.ya?ml$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/\\.tf$/",
        "/\\.ya?ml$/"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>.*?) depName=(?<depName>\\S+)(?:\\s+(?:repository-url|registryUrl)=(?<registryUrl>\\S+))?(?:\\s+versioning=(?<versioning>.*?))?(?:\\s+extractVersion=(?<extractVersion>.*?))?\\s+(?:default\\s*=\\s*\"|package:\\s*.*:)(?<currentValue>[^\"\\n]+)\"?",
        "#\\s*renovate:\\s*datasource=(?<datasource>.*?) depName=(?<depName>\\S+)(?:\\s+(?:repository-url|registryUrl)=(?<registryUrl>\\S+))?(?:\\s+versioning=(?<versioning>.*?))?(?:\\s+extractVersion=(?<extractVersion>.*?))?\\s+tag\\s*:\\s*\"?(?<currentValue>[^\"\\n]+)\"?"
      ]
    },
    {
      "customType": "regex",
      "description": "Track pinned nix run github refs in cloud-edge workflow",
      "managerFilePatterns": [
        "/(^|/)\\.github/workflows/cloud-edge\\.ya?ml$/"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)(?:\\s+versioning=(?<versioning>\\S+))?\\s+nix\\s+run\\s+github:[^/\\s]+/[^/\\s]+/(?<currentValue>[^\\s#]+)(?:#[^\\s]+)?",
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)\\s+packageName=(?<packageName>\\S+)\\s+ref=(?<currentValue>\\S+)(?:\\s+versioning=(?<versioning>\\S+))?\\s+nix\\s+run\\s+github:[^/\\s]+/[^/\\s]+/(?<currentDigest>[0-9a-f]{40})#[^\\s]+"
      ]
    }
  ],
  "packageRules": [
    {
      "description": "Group Terraform provider updates (excluding infrastructure-critical)",
      "matchManagers": [
        "terraform"
      ],
      "groupName": "terraform providers",
      "matchPackageNames": [
        "!/talos/",
        "!/proxmox/"
      ]
    },
    {
      "description": "Talos provider",
      "matchManagers": [
        "terraform"
      ],
      "labels": [
        "dependencies",
        "infrastructure-critical"
      ],
      "matchPackageNames": [
        "/talos/"
      ]
    },
    {
      "description": "Proxmox provider",
      "matchManagers": [
        "terraform"
      ],
      "labels": [
        "dependencies",
        "infrastructure-critical"
      ],
      "matchPackageNames": [
        "/proxmox/"
      ]
    },
    {
      "description": "Helm charts",
      "matchManagers": [
        "terraform",
        "argocd"
      ],
      "matchDatasources": [
        "helm"
      ],
      "groupName": "helm charts",
      "labels": [
        "dependencies",
        "helm"
      ]
    },
    {
      "description": "Kubernetes version",
      "matchPackageNames": [
        "kubernetes/kubernetes"
      ],
      "labels": [
        "dependencies",
        "infrastructure-critical"
      ]
    },
    {
      "description": "Talos OS version",
      "matchPackageNames": [
        "siderolabs/talos"
      ],
      "labels": [
        "dependencies",
        "infrastructure-critical"
      ]
    }
  ]
}
